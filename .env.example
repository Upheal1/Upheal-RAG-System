# Upheal Environment Variables
# Standardized variables for reproducible Index, Testing, and Deployments.

# ChromaDB Configuration for RAG
UPHEAL_CHROMA_PATH=./data/vector_db_mini_enriched
UPHEAL_CHROMA_COLLECTION=clinical_rag_mini
UPHEAL_EMBEDDING_MODEL=all-mpnet-base-v2

# Web Server overrides
HOST=0.0.0.0
PORT=8000

# LLM Configuration (Formatter Agent)
# Add either OpenAI or Gemini key to enable LLM labeling
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=ai...
