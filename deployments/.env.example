# UpHeal Environment Configuration

# ChromaDB Configuration
UPHEAL_CHROMA_PATH=./data/vector_db_mini
UPHEAL_CHROMA_COLLECTION=clinical_rag_mini

# LLM Configuration - Choose one:

# Option 1: Hugging Face Inference API (FREE - $0.10/month, very limited)
# Get token: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 2: OpenAI (RECOMMENDED - $5 free for new accounts)
# Sign up at https://platform.openai.com
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option 3: Google Gemini
GOOGLE_API_KEY=

# Option 4: Ollama (self-hosted, free but needs GPU)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# Logging
LOG_LEVEL=INFO

# Application
PYTHONUNBUFFERED=1

# Supabase Auth JWT Secret (REQUIRED for production)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here